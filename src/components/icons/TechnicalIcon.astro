---
export type TechnicalIconName =
  | "arrow"
  | "idea"
  | "design"
  | "code"
  | "launch"
  | "mail"
  | "telegram"
  | "globe";

interface Props {
  name: TechnicalIconName;
  class?: string;
}

const { name, class: className } = Astro.props;
---

<svg
  class:list={["technical-icon", className]}
  viewBox="0 0 32 32"
  aria-hidden="true"
  focusable="false"
>
  {
    name === "arrow" && (
      <>
        <path d="M5 16h20" />
        <path d="m18 9 7 7-7 7" />
      </>
    )
  }
  {
    name === "idea" && (
      <>
        <path d="M10.5 20.5c-2-1.7-3.2-4-3.2-6.6A8.7 8.7 0 0 1 16 5.2a8.7 8.7 0 0 1 8.7 8.7c0 2.6-1.2 4.9-3.2 6.6-1.1 1-1.7 2-1.8 3.2h-7.4c-.1-1.2-.7-2.2-1.8-3.2Z" />
        <path d="M12.5 27h7M13.7 23.7v3.2M18.3 23.7v3.2M16 1.7v1.8M4.1 6l1.3 1.3M27.9 6l-1.3 1.3M1.8 15h2M28.2 15h2" />
      </>
    )
  }
  {
    name === "design" && (
      <>
        <rect x="5" y="6" width="22" height="17" />
        <path d="m8 20 6.5-6.5 4.2 4.2 2.2-2.2 3.1 3.1M11 27h10M16 23v4M21.5 10.5h.1" />
      </>
    )
  }
  {
    name === "code" && (
      <>
        <path d="m11.5 8-8 8 8 8M20.5 8l8 8-8 8M18.7 4.5l-5.4 23" />
      </>
    )
  }
  {
    name === "launch" && (
      <>
        <path d="M18.5 5.2c3.3-2 6.7-1.7 8.3-1.5.2 1.7.5 5-1.5 8.4l-7.1 7.1-5.3-5.3 5.6-8.7Z" />
        <path d="m12.9 13.9-5.5 1.3-3.2 3.2 7.2 1.2M18.2 19.2l-1.3 5.5-3.2 3.2-1.2-7.2M20.8 8.8h.1M8.8 23.2c-1 1-1.5 2.4-1.4 4.1 1.7.1 3.1-.4 4.1-1.4" />
      </>
    )
  }
  {
    name === "mail" && (
      <>
        <rect x="3.5" y="6.5" width="25" height="19" />
        <path d="m4 8 12 9 12-9" />
      </>
    )
  }
  {
    name === "telegram" && (
      <>
        <path d="m3 15.2 25.5-10-4.3 21.4-7.6-6-4.5 4.2.8-7.5L24.2 9l-13.8 7-7.4-.8Z" />
      </>
    )
  }
  {
    name === "globe" && (
      <>
        <circle cx="16" cy="16" r="12" />
        <path d="M4 16h24M16 4c4 3.3 6 7.3 6 12s-2 8.7-6 12c-4-3.3-6-7.3-6-12s2-8.7 6-12Z" />
      </>
    )
  }
</svg>
